{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "appsinvest/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-bcmath": "*",
        "ext-curl": "*",
        "ext-http": "*",
        "ext-redis": "*",
        "ext-zlib": "*",
        "darkaonline/l5-swagger": "^11.0",
        "laravel/framework": "^12.43",
        "laravel/horizon": "^5.41",
        "laravel/tinker": "^2.10.1",
        "vladimir-yuldashev/laravel-queue-rabbitmq": "^14.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/pail": "^1.2.4",
        "laravel/pint": "^1.26",
        "barryvdh/laravel-ide-helper": "^3.6",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.8",
        "phpunit/phpunit": "^11.5.46",
        "larastan/larastan": "^v3.8.1",
        "nunomaduro/phpinsights": "^2.13",
        "phpstan/phpstan": "^2.1",
        "slevomat/coding-standard": "~8.22",
        "squizlabs/php_codesniffer": "^3.13",
        "vimeo/psalm": "^6.14",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpstan/phpstan-strict-rules": "^2.0",
        "driftingly/rector-laravel": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "cs-check": "phpcs . --standard=ruleset.xml",
        "cs-fix": "phpcbf . --standard=ruleset.xml",
        "phpstan": "phpstan analyse --configuration=phpstan.neon --memory-limit=512M --no-progress --error-format=github --no-interaction --ansi",
        "lint": "vendor/bin/parallel-lint --exclude .git --exclude vendor .",
        "psalm": "vendor/bin/psalm --no-cache -c=./psalm.xml",
        "tests": "vendor/bin/phpunit",
        "openapi": "@php artisan l5-swagger:generate",
        "rector": "rector process --clear-cache --dry-run --memory-limit=1024M",
        "rector-fix": "rector process --clear-cache --memory-limit=1024M"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
